# Copy to `.env` and change the secrets BEFORE `docker compose up -d`.
POSTGRES_USER=vitech
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=vitech

FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=change-me-strong

# LLM served by Ollama (Llama 3.1 on the RunPod GPU).
# Must be a tool-capable model — Flowise's Tool Agent needs native tool-calling,
# which base `llama3` does NOT expose (`ollama show` -> capabilities has no
# `tools`). llama3.1:8b / qwen2.5 do. Check: curl :11434/api/show -d '{"model":"..."}'
OLLAMA_MODEL=llama3.1:8b
