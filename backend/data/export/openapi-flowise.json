    "/api/tools/retrieve": {
      "post": {
        "summary": "Tool Retrieve",
        "description": "Search the engineering knowledge base (ingested reference documents:\nstandards, catalogs, past-offer source files) with an optional metadata\nfilter applied BEFORE semantic search. This is the Engineering Agent's\n'search ChromaDB' step \u2014 it grounds the narrative, while the numbers still\ncome from /api/tools/spec. Never reasons over the numbers itself.\n\nBody: {\"question\": \"...\", \"top_k\": 6,\n       \"filters\": {\"equipment_type\": \"wet_scrubber\", \"section\": \"technical_specification\"}}\n(filter keys may also be passed at the top level for convenience).",
        "operationId": "retrieve_knowledge",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": true,
                "type": "object",
                "title": "Payload"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
